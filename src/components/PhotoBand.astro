---
import { Image } from "astro:assets";

interface Props {
  photos: { src: ImageMetadata; alt: string; caption: string }[];
}
const { photos } = Astro.props;
const [big, ...rest] = photos;
---

<section class="band">
  <h2>Life here</h2>
  <div class="grid">
    <figure class="big">
      <button type="button" class="lightbox-open" aria-label={`View larger: ${big.alt}`}>
        <Image
          src={big.src}
          alt={big.alt}
          widths={[480, 800, 1200]}
          sizes="(max-width: 40rem) 100vw, 60vw"
          loading="lazy"
        />
      </button>
      <figcaption>{big.caption}</figcaption>
    </figure>
    {rest.map((p) => (
      <figure>
        <button type="button" class="lightbox-open" aria-label={`View larger: ${p.alt}`}>
          <Image
            src={p.src}
            alt={p.alt}
            widths={[480, 800]}
            sizes="(max-width: 40rem) 100vw, 40vw"
            loading="lazy"
          />
        </button>
        <figcaption>{p.caption}</figcaption>
      </figure>
    ))}
  </div>
</section>

<style>
  .band {
    margin: 0 0 4rem;
  }
  .grid {
    display: grid;
    grid-template-columns: 3fr 2fr;
    grid-template-rows: repeat(2, minmax(0, 18rem));
    gap: 1.25rem;
  }
  .big {
    grid-row: span 2;
  }
  figure {
    margin: 0;
    display: flex;
    flex-direction: column;
  }
  figure .lightbox-open {
    flex: 1;
    min-height: 0;
  }
  img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 8px;
  }
  figcaption {
    font-size: 0.82rem;
    color: var(--muted);
    margin-top: 0.4rem;
  }
  @media (max-width: 40rem) {
    .grid {
      grid-template-columns: 1fr;
      grid-template-rows: none;
    }
    .big {
      grid-row: auto;
    }
    figure .lightbox-open {
      flex: none;
    }
    img {
      height: 14rem;
    }
  }
</style>
