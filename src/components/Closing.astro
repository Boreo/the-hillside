---
import { Image } from "astro:assets";

interface Props {
  image: { src: ImageMetadata; alt: string };
  line: string;
}
const { image, line } = Astro.props;
---

<section class="closing">
  <Image
    src={image.src}
    alt={image.alt}
    widths={[480, 800, 1200, 1600]}
    sizes="(max-width: 71rem) 100vw, 68rem"
    loading="lazy"
  />
  <p>{line}</p>
  <a class="btn" href="/book/">Book with us</a>
</section>

<style>
  .closing {
    text-align: center;
    margin: 0 0 2rem;
  }
  img {
    width: 100%;
    max-height: 24rem;
    object-fit: cover;
    border-radius: 8px;
  }
  .closing p {
    font-family: "Fraunces Variable", Georgia, serif;
    font-variation-settings: "SOFT" 60, "WONK" 0;
    font-weight: 500;
    font-size: clamp(1.2rem, 2.5vw, 1.5rem);
    color: var(--accent-dark);
    margin: 1.5rem 0 1.25rem;
  }
</style>
