---
import { Image } from "astro:assets";
import FactIcon from "./FactIcon.astro";
import { FACT_ICON_PATHS } from "../lib/fact-icon-paths.mjs";

interface Fact {
  icon: "walk" | "car" | "calendar";
  label: string;
}
interface Place {
  name: string;
  facts: Fact[];
  tag?: string;
  blurb: string;
  link?: { href: string; label: string };
  image?: { src: ImageMetadata; alt: string };
}
interface Props {
  groups: { heading: string; intro?: string; places: Place[] }[];
}
const { groups } = Astro.props;

// Card photos share the CSS-only :target lightbox used by markdown pages
// (styles in global.css). Ids are prefixed to avoid clashing with the
// rehype-generated #photo-N overlays if a page has both.
const photos = groups.flatMap((g) => g.places).filter((p) => p.image);
const photoIndex = (p: Place) => photos.indexOf(p);

// Group intros are plain frontmatter strings but may carry markdown links
// (e.g. to the QPWS track map). Escape everything, then rebuild only the
// [text](url) links as anchors.
const escapeHtml = (s: string) =>
  s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
const outIcon = `<svg class="fact-icon out-icon" viewBox="0 0 256 256" aria-hidden="true"><path fill="currentColor" d="${FACT_ICON_PATHS["arrow-out"]}"/></svg>`;
const renderIntro = (s: string) =>
  escapeHtml(s).replace(
    /\[([^\]]+)\]\(([^)\s]+)\)/g,
    (_, label, href) =>
      `<a href="${href}">${label}${href.startsWith("http") ? outIcon : ""}</a>`,
  );
---

{
  groups.map((group) => (
    <section class="place-group">
      <h2>{group.heading}</h2>
      {group.intro && <p class="place-intro" set:html={renderIntro(group.intro)} />}
      <div class="place-grid">
        {group.places.map((p) => (
          <article class="place-card">
            {p.image && (
              <a
                href={`#place-photo-${photoIndex(p) + 1}`}
                class="lightbox-open"
                aria-label={`Enlarge photo: ${p.image.alt}`}
              >
                <Image
                  src={p.image.src}
                  alt={p.image.alt}
                  widths={[480, 800]}
                  sizes="(max-width: 40rem) 100vw, 30rem"
                />
              </a>
            )}
            <h3>{p.name}</h3>
            {(p.facts.length > 0 || p.tag) && (
              <p class="place-facts">
                {p.facts.map((f) => (
                  <span class="place-fact">
                    <FactIcon name={f.icon} /> {f.label}
                  </span>
                ))}
                {p.tag && <span class="place-tag">{p.tag}</span>}
              </p>
            )}
            <p class="place-blurb">
              {p.blurb
                .trim()
                .split("\n")
                .map((line) => (
                  <span>{line}</span>
                ))}
            </p>
            {p.link && (
              <a class="place-link" href={p.link.href}>
                {p.link.label}
                {p.link.href.startsWith("http") && <FactIcon name="arrow-out" />}
              </a>
            )}
          </article>
        ))}
      </div>
    </section>
  ))
}
{
  photos.map((p, i) => {
    const prev = ((i - 1 + photos.length) % photos.length) + 1;
    const next = ((i + 1) % photos.length) + 1;
    return (
      <div id={`place-photo-${i + 1}`} class="lightbox">
        <a href="#_" class="lightbox-backdrop" aria-label="Close enlarged photo" />
        <Image src={p.image!.src} alt={p.image!.alt} widths={[1200, 2000]} sizes="100vw" loading="lazy" />
        <span class="lightbox-meta">
          <span class="lightbox-caption">{p.image!.alt}</span>
          <span class="lightbox-counter">{`${i + 1} / ${photos.length}`}</span>
        </span>
        <a href={`#place-photo-${prev}`} class="lightbox-prev" aria-label="Previous photo">
          ←
        </a>
        <a href={`#place-photo-${next}`} class="lightbox-next" aria-label="Next photo">
          →
        </a>
        <a href="#_" class="lightbox-close" aria-label="Close enlarged photo">
          ×
        </a>
      </div>
    );
  })
}
