---

interface Props {
  video: { src: string; poster: ImageMetadata };
  line: string;
}
const { video, line } = Astro.props;
---

<section class="hero">
  <video
    class="hero-video"
    src={video.src}
    poster={video.poster.src}
    autoplay
    muted
    loop
    playsinline
    aria-label="Aerial drone view over The Hillside Retreat towards the Gold Coast skyline"
  />
  <div class="hero-overlay">
    <h1 class="hero-line">{line}</h1>
    <a class="btn-glass" href="/book/">Check availability</a>
  </div>
</section>

<style>
  /* Inset video panel: rounded, page background visible around it, text overlaid on a scrim. */
  .hero {
    position: relative;
    margin: 0 0 4rem;
    min-height: clamp(22rem, 65vh, 38rem);
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    border-radius: 12px;
  }
  .hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0;
  }
  .hero-overlay {
    position: relative;
    width: 100%;
    padding: 6rem 2.5rem 2.5rem;
    background: linear-gradient(to top, rgb(9 47 28 / 0.85), rgb(9 47 28 / 0.45) 55%, transparent);
  }
  .hero-line {
    font-family: "Fraunces Variable", Georgia, serif;
    font-variation-settings: "SOFT" 60, "WONK" 0;
    font-weight: 500;
    font-size: clamp(1.9rem, 4vw, 2.8rem);
    line-height: 1.2;
    color: var(--paper);
    max-width: 30ch;
    text-wrap: balance;
    margin: 0 0 1.25rem;
  }
</style>
