---
import { getReview, attribution } from "../lib/reviews";

interface Props {
  reviewId: string;
  excerpt: string;
}
const { reviewId, excerpt } = Astro.props;

const review = await getReview(reviewId);
---

<section class="pull-quote full-bleed">
  <blockquote>
    <p>“{excerpt}”</p>
    <footer>{attribution(review)}</footer>
  </blockquote>
</section>

<!-- Styled by the shared .pull-quote quote-band rules in global.css. -->
