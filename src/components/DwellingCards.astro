---
import { getEntry } from "astro:content";
import { Image } from "astro:assets";
import FactIcon from "./FactIcon.astro";
import combinedAerial from "../assets/images/drone/aerial-view-whole-property.jpg";

interface Props {
  dwellings: {
    slug: string;
    href: string;
    image: { src: ImageMetadata; alt: string };
    line: string;
  }[];
  combinedLine: string;
}
const { dwellings, combinedLine } = Astro.props;

const cards = await Promise.all(
  dwellings.map(async (d) => {
    const entry = await getEntry("pages", d.slug);
    const facts = entry?.data.dwelling;
    if (!facts) throw new Error(`No dwelling frontmatter on ${d.slug}`);
    return { ...d, facts };
  }),
);

const factsParts = (f: (typeof cards)[number]["facts"]) => ({
  sleeps: `Sleeps ${f.sleeps}`,
  bedrooms: `${f.bedrooms.length} ${f.bedrooms.length === 1 ? "bedroom" : "bedrooms"}`,
  bathrooms: `${f.bathrooms} ${f.bathrooms === 1 ? "bathroom" : "bathrooms"}`,
});
---

<section class="dwellings" id="accommodation">
  <h2>Two places to stay</h2>
  <div class="pair">
    {cards.map((card) => (
      <article>
        <Image
          src={card.image.src}
          alt={card.image.alt}
          widths={[480, 800, 1200]}
          sizes="(max-width: 40rem) 100vw, 50vw"
          loading="lazy"
        />
        <h3>{card.facts.name}</h3>
        <p class="facts-line">
          <span><FactIcon name="users" /> {factsParts(card.facts).sleeps}</span>
          <span><FactIcon name="bed" /> {factsParts(card.facts).bedrooms}</span>
          <span><FactIcon name="bathtub" /> {factsParts(card.facts).bathrooms}</span>
        </p>
        <p>{card.line}</p>
        <a class="btn" href={card.href}>See {card.facts.name}</a>
      </article>
    ))}
  </div>
  <article class="combined">
    <Image
      src={combinedAerial}
      alt="Aerial view of the whole property, House and Villa together on the hillside"
      widths={[480, 800, 1200]}
      sizes="(max-width: 40rem) 100vw, 55vw"
      loading="lazy"
    />
    <div>
      <h3>House &amp; Villa combined</h3>
      <p class="facts-line">
        <span><FactIcon name="users" /> Sleeps 8</span>
        <span><FactIcon name="bed" /> 4 bedrooms</span>
      </p>
      <p>{combinedLine}</p>
      <a class="btn btn-outline" href="/house-and-villa/">About House &amp; Villa</a>
    </div>
  </article>
</section>

<style>
  .dwellings {
    margin: 0 0 4rem;
  }
  .pair {
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    column-gap: 2.5rem;
  }
  article {
    border-top: 2px solid var(--highlight);
    padding-top: 1.25rem;
  }
  /* Both image blocks end at the same y: the Villa image's top margin
     (11.25% of its column) equals the height its narrower 4:3 image loses
     against the wider House column, so titles and facts lines align while
     the top edge staggers. Buttons bottom-align via margin-top: auto. */
  .pair article {
    display: flex;
    flex-direction: column;
  }
  .pair article:nth-child(2) img {
    margin-top: 11.25%;
  }
  .pair article .btn {
    margin-top: auto;
    align-self: flex-start;
  }
  article img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: 8px;
  }
  article h3 {
    margin: 1rem 0 0.25rem;
  }
  article .btn {
    margin-top: 0.5rem;
  }
  .combined {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 2.5rem;
    align-items: center;
    margin-top: 3rem;
    border-top: 2px solid var(--highlight);
    padding-top: 1.25rem;
  }
  .combined img {
    aspect-ratio: 16 / 9;
  }
  .combined h3 {
    margin: 0 0 0.25rem;
  }
  .combined p {
    text-wrap: balance;
    margin: 0 0 0.5rem;
  }
  @media (max-width: 40rem) {
    .pair {
      grid-template-columns: 1fr;
    }
    .pair article:nth-child(2) {
      margin-top: 2.5rem;
    }
    .pair article:nth-child(2) img {
      margin-top: 0;
    }
    .combined {
      grid-template-columns: 1fr;
    }
  }
</style>
