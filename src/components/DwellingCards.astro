---
import { getEntry } from "astro:content";

interface Props {
  dwellings: {
    slug: string;
    href: string;
    image: { src: string; alt: string };
    line: string;
  }[];
  combinedLine: string;
}
const { dwellings, combinedLine } = Astro.props;

const cards = await Promise.all(
  dwellings.map(async (d) => {
    const entry = await getEntry("pages", d.slug);
    const facts = entry?.data.dwelling;
    if (!facts) throw new Error(`No dwelling frontmatter on ${d.slug}`);
    return { ...d, facts };
  }),
);

const factsLine = (f: (typeof cards)[number]["facts"]) =>
  `Sleeps ${f.sleeps} · ${f.bedrooms.length} ${f.bedrooms.length === 1 ? "bedroom" : "bedrooms"}`;
---

<section class="dwellings">
  <h2>Two places to stay</h2>
  <div class="pair">
    {cards.map((card) => (
      <article>
        <img src={card.image.src} alt={card.image.alt} loading="lazy" />
        <h3>{card.facts.name}</h3>
        <p class="facts-line">{factsLine(card.facts)}</p>
        <p>{card.line}</p>
        <a class="editorial-link" href={card.href}>See {card.facts.name}</a>
      </article>
    ))}
  </div>
  <p class="combined">
    {combinedLine}
    <a class="editorial-link" href="/house-and-villa/">About House &amp; Villa</a>
  </p>
</section>

<style>
  .dwellings {
    margin: 0 0 5rem;
  }
  .pair {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem;
  }
  article {
    border-top: 2px solid var(--highlight);
    padding-top: 1.25rem;
  }
  article:nth-child(2) {
    margin-top: 2.5rem;
  }
  article img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: 3px;
  }
  article h3 {
    margin: 1rem 0 0.25rem;
  }
  .facts-line {
    text-transform: uppercase;
    letter-spacing: 0.09em;
    font-size: 0.72rem;
    color: var(--muted);
    font-weight: 600;
    margin: 0 0 0.75rem;
  }
  .combined {
    max-width: 44rem;
    margin-top: 3rem;
    padding-top: 1rem;
    border-top: 1px solid var(--line);
    color: var(--muted);
  }
  @media (max-width: 40rem) {
    .pair {
      grid-template-columns: 1fr;
    }
    article:nth-child(2) {
      margin-top: 0;
    }
  }
</style>
