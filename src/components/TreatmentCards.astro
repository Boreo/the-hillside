---
import FactIcon from "./FactIcon.astro";

interface Fact {
  icon: "clock";
  label: string;
}
interface Treatment {
  name: string;
  facts: Fact[];
  tag?: string;
  blurb?: string;
  addons?: string;
}
interface Props {
  groups: { heading: string; intro?: string; treatments: Treatment[] }[];
}
const { groups } = Astro.props;
---

{
  groups.map((group) => (
    <section class="place-group">
      <h2>{group.heading}</h2>
      {group.intro && <p class="place-intro">{group.intro}</p>}
      <div class="place-grid">
        {group.treatments.map((t) => (
          <article class="place-card">
            <h3>{t.name}</h3>
            {(t.facts.length > 0 || t.tag) && (
              <p class="place-facts">
                {t.facts.map((f) => (
                  <span class="place-fact">
                    <FactIcon name={f.icon} /> {f.label}
                  </span>
                ))}
                {t.tag && <span class="place-tag">{t.tag}</span>}
              </p>
            )}
            {t.blurb && <p class="place-blurb">{t.blurb.trim()}</p>}
            {t.addons && <p class="treatment-addons">{t.addons}</p>}
          </article>
        ))}
      </div>
    </section>
  ))
}
