---
import { Image } from "astro:assets";
import FactsLine from "./FactsLine.astro";

interface Props {
  dwelling: {
    name: string;
    hero: { src: ImageMetadata; alt: string };
    sleeps: number;
    bedrooms: { bed: string; sleeps: number; ensuite: boolean }[];
    bathrooms: number;
    amenities: string[];
    cta: { label: string; href: string };
  };
}
const { dwelling } = Astro.props;
---

<section class="dwelling-header full-bleed full-bleed-pad">
  <div class="dwelling-header-info">
    <h1>{dwelling.name}</h1>
    <FactsLine
      sleeps={dwelling.sleeps}
      bedrooms={dwelling.bedrooms.length}
      bathrooms={dwelling.bathrooms}
    />
    <ul class="amenities-line">
      {dwelling.amenities.map((a) => <li>{a}</li>)}
    </ul>
    <a class="btn" href={dwelling.cta.href}>{dwelling.cta.label}</a>
  </div>
  <Image
    src={dwelling.hero.src}
    alt={dwelling.hero.alt}
    widths={[480, 800, 1200]}
    sizes="(max-width: 40rem) 100vw, 55vw"
    loading="eager"
  />
</section>
<div class="dwelling-body">
  <slot />
</div>

<style>
  /* Split header: info column beside a staggered rounded image, the
     dwelling-cards treatment at page scale, on a full-bleed sage band
     (same breakout as ReviewBand) so the header reads as its own section. */
  .dwelling-header {
    display: grid;
    grid-template-columns: 1fr 1.15fr;
    column-gap: 2.5rem;
    align-items: start;
    background: var(--wash);
    margin-block: -1rem 3rem;
    padding-block: 2rem 2.75rem;
  }
  .dwelling-header-info {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding-top: 2.5rem;
  }
  .dwelling-header h1 {
    font-size: clamp(2rem, 4.5vw, 3rem);
    line-height: 1.1;
    margin: 0 0 1rem;
  }
  .dwelling-header :global(.facts-line) {
    margin: 0 0 0.75rem;
  }
  /* Amenities as soft chips. */
  .amenities-line {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding: 0;
    margin: 0 0 1.75rem;
    max-width: 30rem;
  }
  .amenities-line li {
    font-family: system-ui, sans-serif;
    font-size: 0.8rem;
    color: var(--muted);
    background: var(--card);
    border: 1px solid var(--mint);
    border-radius: 4px;
    padding: 0.25rem 0.65rem;
  }
  .dwelling-header img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: 8px;
    margin-top: 5%;
  }
  @media (max-width: 40rem) {
    .dwelling-header {
      grid-template-columns: 1fr;
    }
    .dwelling-header-info {
      padding-top: 0;
    }
    .dwelling-header img {
      margin-top: 1.5rem;
      order: 2;
    }
  }
</style>
