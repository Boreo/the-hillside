---
import FactIcon from "./FactIcon.astro";
import { factLabels } from "../lib/dwelling-facts.mjs";
import type { FACT_ICON_PATHS } from "../lib/fact-icon-paths.mjs";

interface Props {
  sleeps: number;
  bedrooms: number;
  bathrooms: number;
}
const facts = Astro.props;
---

<p class="facts-line">
  {
    factLabels(facts).map(([icon, label]) => (
      <span>
        <FactIcon name={icon as keyof typeof FACT_ICON_PATHS} /> {label}
      </span>
    ))
  }
</p>
