---
interface Props {
  paragraphs: string[];
}
const { paragraphs } = Astro.props;
---

<section class="arrival">
  {paragraphs.map((p) => <p>{p}</p>)}
</section>

<style>
  .arrival {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem 3.5rem;
    margin: 0 0 4rem;
  }
  .arrival p {
    font-size: 1.15rem;
    margin: 0;
    white-space: pre-line;
  }
  @media (max-width: 40rem) {
    .arrival {
      grid-template-columns: 1fr;
    }
  }
</style>
