---
import "../styles/global.css";
import "@fontsource-variable/fraunces/index.css";
import frauncesWoff2 from "@fontsource-variable/fraunces/files/fraunces-latin-wght-normal.woff2?url";
import { getCollection } from "astro:content";
import { Image, getImage } from "astro:assets";
import LightboxViewer from "../components/LightboxViewer.astro";
import emblem from "../assets/images/the-hillside-retreat-emblem.png";
import heroPoster from "../assets/images/hero-poster.jpg";
import type { ImageMetadata } from "astro";

export const BOOK_URL = "/book/";

/** Stable node identity for the business, referenced from per-page JSON-LD
 * (dwelling containedInPlace, review itemReviewed) so answer engines merge
 * every page's structured data into one entity. */
export const BUSINESS_ID = "https://www.thehillside.com.au/#business";

interface Props {
  title: string;
  description?: string;
  /** Page-specific structured data, emitted alongside the LodgingBusiness JSON-LD. */
  extraJsonLd?: object | object[];
  /** Share image for link previews; defaults to the hero drone still. */
  ogImage?: ImageMetadata;
  preloadImage?: string;
}

const { title, description = "The Hillside Retreat — secluded accommodation on Tamborine Mountain in the Gold Coast Hinterland, with coastal views, pool and heated spa.", extraJsonLd, ogImage = heroPoster, preloadImage } = Astro.props;

// Pages pass a bare page name; the site name is appended here. A title that
// already carries the site name (the homepage) is used as-is.
const fullTitle = title.includes("The Hillside Retreat")
  ? title
  : `${title} — The Hillside Retreat`;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);

const ogImageOptimized = await getImage({
  src: ogImage,
  width: 1200,
  format: "jpg",
});
const ogImageUrl = new URL(ogImageOptimized.src, Astro.site);

const nav = [
  {
    href: "/#accommodation",
    label: "Accommodation",
    children: [
      { href: "/hillside-house/", label: "Hillside House" },
      { href: "/hillside-villa/", label: "Hillside Villa" },
      { href: "/house-and-villa/", label: "House & Villa" },
    ],
  },
  { href: "/gallery/", label: "Gallery" },
  { href: "/reviews/", label: "Reviews" },
  {
    href: "/guest-info/",
    label: "Your Stay",
    children: [
      { href: "/location/", label: "Location" },
      { href: "/faq/", label: "FAQ" },
      { href: "/guest-info/", label: "Guest Info" },
      { href: "/mountain-mobile-massage/", label: "Mobile Massage" },
    ],
  },
  { href: "/contact-us/", label: "Your Hosts" },
];

// Footer "Explore" column: every leaf page from the nav (dropdown children
// replace their parent link).
const footerLinks = nav.flatMap((item) =>
  "children" in item && item.children ? item.children : [item],
);

// Cross-platform aggregate rating, weighted by review count and normalised
// to a 5-point scale (Booking.com scores out of 10).
const ratedSources = (await getCollection("reviewSources")).filter(
  ({ data }) => data.rating !== null && data.count !== null,
);
const totalReviews = ratedSources.reduce((sum, { data }) => sum + data.count!, 0);
const weightedRating =
  ratedSources.reduce(
    (sum, { data }) => sum + (data.rating! / data.scale) * 5 * data.count!,
    0,
  ) / totalReviews;

const heroPosterOptimized = await getImage({ src: heroPoster, width: 1200, format: "jpg" });

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": "https://www.thehillside.com.au/#website",
      name: "The Hillside Retreat",
      url: Astro.site!.href,
      publisher: { "@id": BUSINESS_ID },
    },
    {
      "@type": "LodgingBusiness",
      "@id": BUSINESS_ID,
      name: "The Hillside Retreat",
      url: Astro.site!.href,
      description:
        "Secluded, tranquil accommodation on Tamborine Mountain in the Gold Coast Hinterland. Hillside House (3-bedroom, sleeps 6) and Hillside Villa (1-bedroom, sleeps 2), bookable separately or combined for up to 8 guests.",
      email: "stay@thehillside.com.au",
      telephone: "+61466990185",
      image: [new URL(heroPosterOptimized.src, Astro.site).href],
      address: {
        "@type": "PostalAddress",
        streetAddress: "25 Leona Court",
        addressLocality: "Tamborine Mountain",
        addressRegion: "QLD",
        postalCode: "4272",
        addressCountry: "AU",
      },
      geo: {
        "@type": "GeoCoordinates",
        latitude: -27.957222,
        longitude: 153.224167,
      },
      priceRange: "AUD $260–$635 per night",
      sameAs: ratedSources.map(({ data }) => data.url),
      checkinTime: "14:00",
      checkoutTime: "10:00",
      petsAllowed: false,
      aggregateRating: {
        "@type": "AggregateRating",
        ratingValue: Number(weightedRating.toFixed(2)),
        bestRating: 5,
        reviewCount: totalReviews,
      },
      amenityFeature: [
        { "@type": "LocationFeatureSpecification", name: "Pool and heated spa", value: true },
        { "@type": "LocationFeatureSpecification", name: "EV charging (7.3 kW Type 2)", value: true },
        { "@type": "LocationFeatureSpecification", name: "Free private parking", value: true },
        { "@type": "LocationFeatureSpecification", name: "Wi-Fi", value: true },
        { "@type": "LocationFeatureSpecification", name: "Wood fireplace", value: true },
      ],
      potentialAction: {
        "@type": "ReserveAction",
        target: {
          "@type": "EntryPoint",
          urlTemplate: new URL(BOOK_URL, Astro.site).href,
          actionPlatform: [
            "https://schema.org/DesktopWebPlatform",
            "https://schema.org/MobileWebPlatform",
          ],
        },
      },
    },
  ],
};

const extraJsonLdBlocks = extraJsonLd
  ? Array.isArray(extraJsonLd)
    ? extraJsonLd
    : [extraJsonLd]
  : [];
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalUrl} />
<link rel="preload" as="font" type="font/woff2" crossorigin href={frauncesWoff2} />
<link rel="icon" href="/favicon.ico" sizes="32x32" />
<link rel="icon" href="/icon-192.png" type="image/png" sizes="192x192" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
{preloadImage && <link rel="preload" as="image" href={preloadImage} />}
<meta property="og:type" content="website" />
<meta property="og:site_name" content="The Hillside Retreat" />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:width" content={String(ogImageOptimized.attributes.width)} />
<meta property="og:image:height" content={String(ogImageOptimized.attributes.height)} />
<meta name="twitter:card" content="summary_large_image" />
<script defer src="https://cloud.umami.is/script.js" data-website-id="a3ea87f9-e118-444b-8a27-49aa9ac101cb"></script>
<script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
{extraJsonLdBlocks.map((block) => (
  <script is:inline type="application/ld+json" set:html={JSON.stringify(block)} />
))}

<header>
  <a href="/" class="brand">
    <Image src={emblem} alt="" height={64} densities={[1, 2]} loading="eager" />
    <span class="brand-name">The Hillside Retreat</span>
  </a>
  <nav id="site-nav">
    {nav.map((item) =>
      "children" in item && item.children ? (
        <div class="nav-drop">
          <a class="nav-parent" href={item.href} aria-haspopup="true">
            {item.label} <span class="caret" aria-hidden="true">▾</span>
          </a>
          <div class="drop-menu">
            {item.children.map((c) => <a href={c.href}>{c.label}</a>)}
          </div>
        </div>
      ) : (
        <a href={item.href}>{item.label}</a>
      ),
    )}
  </nav>
  <a class="btn nav-book" href={BOOK_URL} data-umami-event="booking-click">Book Direct</a>
  <button class="nav-toggle" aria-expanded="false" aria-controls="site-nav" aria-label="Menu">
    <span aria-hidden="true"></span>
    <span aria-hidden="true"></span>
    <span aria-hidden="true"></span>
  </button>
</header>

<script>
  const header = document.querySelector("header")!;
  const toggle = document.querySelector<HTMLButtonElement>(".nav-toggle");
  toggle?.addEventListener("click", () => {
    const open = header.classList.toggle("nav-open");
    toggle.setAttribute("aria-expanded", String(open));
  });

  // Wide touch devices (tablets) get no hover: first tap opens the dropdown,
  // a second tap on the parent follows its link. Desktop keeps hover + plain
  // click. Below the mobile breakpoint the panel shows sub-links inline, so
  // parent links navigate on first tap.
  if (window.matchMedia("(hover: none) and (min-width: 56.0625rem)").matches) {
    const drops = document.querySelectorAll<HTMLElement>(".nav-drop");
    drops.forEach((drop) => {
      const parent = drop.querySelector<HTMLAnchorElement>(".nav-parent");
      parent?.addEventListener("click", (e) => {
        if (!drop.classList.contains("open")) {
          e.preventDefault();
          drops.forEach((d) => d.classList.remove("open"));
          drop.classList.add("open");
        }
      });
    });
    document.addEventListener("click", (e) => {
      if (!(e.target as Element).closest(".nav-drop"))
        drops.forEach((d) => d.classList.remove("open"));
    });
  }
</script>

<main>
  <slot />
</main>

<LightboxViewer />

<footer>
  <div class="footer-inner">
    <div class="footer-brand">
      <span class="footer-brand-row">
        <Image src={emblem} alt="" height={64} densities={[1, 2]} />
        <span class="footer-wordmark">The Hillside Retreat</span>
      </span>
      <p>Secluded, tranquil accommodation on Tamborine Mountain, in the Gold Coast Hinterland.</p>
    </div>
    <nav class="footer-col" aria-label="Footer">
      <h2>Explore</h2>
      <div class="footer-links">
        {footerLinks.map((l) => <a href={l.href}>{l.label}</a>)}
      </div>
    </nav>
    <div class="footer-col">
      <h2>Contact</h2>
      <p>25 Leona Court<br />Tamborine Mountain QLD 4272</p>
      <a href="tel:+61466990185">(+61) 0466 990 185</a>
      <a href="mailto:stay@thehillside.com.au?subject=Enquiry%3A%20Hillside%20Retreat">stay@thehillside.com.au</a>
    </div>
    <div class="footer-col">
      <h2>Book</h2>
      <p>Two hillside dwellings — book one, or both together.</p>
      <a class="btn btn-inverse" href={BOOK_URL}>Book with us</a>
    </div>
  </div>
  <div class="footer-base">
    <p>© {new Date().getFullYear()} The Hillside Retreat · Tamborine Mountain, Queensland</p>
  </div>
</footer>
