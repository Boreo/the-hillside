---
import "../styles/global.css";
import "@fontsource-variable/fraunces/index.css";
import { BOOKING_URL, DEMO_MODE } from "../consts";

interface Props {
  title: string;
  description?: string;
  /** Page-specific structured data, emitted alongside the LodgingBusiness JSON-LD. */
  extraJsonLd?: object;
}

const { title, description = "The Hillside Retreat — secluded accommodation on Tamborine Mountain in the Gold Coast Hinterland, with coastal views, heated pool and spa.", extraJsonLd } = Astro.props;

const nav = [
  {
    href: "/#accommodation",
    label: "Accommodation",
    children: [
      { href: "/hillside-house/", label: "Hillside House" },
      { href: "/hillside-villa/", label: "Hillside Villa" },
      { href: "/house-and-villa/", label: "House & Villa" },
    ],
  },
  {
    href: "/guest-info/",
    label: "Your Stay",
    children: [
      { href: "/location/", label: "Location" },
      { href: "/guest-info/", label: "Guest Info" },
      { href: "/mountain-mobile-massage/", label: "Mobile Massage" },
    ],
  },
  { href: "/gallery/", label: "Gallery" },
  { href: "/reviews/", label: "Reviews" },
  { href: "/contact-us/", label: "Contact" },
  ...(DEMO_MODE ? [{ href: "/palette-demo/", label: "Palette" }] : []),
];

// In demo mode only the homepage, /book/ and /palette-demo/ are shown;
// every other internal link renders disabled.
const demoAllowed = new Set(["/", "/book/", "/palette-demo/", "/#accommodation"]);
const demoHref = (href: string) => (!DEMO_MODE || demoAllowed.has(href) ? href : undefined);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "LodgingBusiness",
  name: "The Hillside Retreat",
  url: "https://www.thehillside.com.au/",
  description:
    "Secluded, tranquil accommodation on Tamborine Mountain in the Gold Coast Hinterland. Hillside House (3-bedroom, sleeps 6) and Hillside Villa (1-bedroom, sleeps 2), bookable separately or combined for up to 8 guests.",
  email: "Stay@thehillside.com.au",
  telephone: "+61466990185",
  address: {
    "@type": "PostalAddress",
    streetAddress: "25 Leona Court",
    addressLocality: "Tamborine Mountain",
    addressRegion: "QLD",
    postalCode: "4272",
    addressCountry: "AU",
  },
  amenityFeature: [
    { "@type": "LocationFeatureSpecification", name: "Heated pool and spa", value: true },
    { "@type": "LocationFeatureSpecification", name: "EV charging (7.3 kW Type 2)", value: true },
    { "@type": "LocationFeatureSpecification", name: "Free private parking", value: true },
    { "@type": "LocationFeatureSpecification", name: "Wi-Fi", value: true },
    { "@type": "LocationFeatureSpecification", name: "Wood fireplace", value: true },
  ],
  potentialAction: {
    "@type": "ReserveAction",
    target: BOOKING_URL,
  },
};
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{title}</title>
<meta name="description" content={description} />
<link rel="icon" href="/favicon.ico" />
<script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
{extraJsonLd && <script is:inline type="application/ld+json" set:html={JSON.stringify(extraJsonLd)} />}

<header>
  <a href="/" class="brand">
    <img src="/images/the-hillside-retreat-emblem.png" alt="" height="64" />
    <span class="brand-name">The Hillside Retreat</span>
  </a>
  <nav>
    {nav.map((item) =>
      "children" in item && item.children ? (
        <div class="nav-drop">
          <a class="nav-parent" href={demoHref(item.href)} aria-haspopup="true">
            {item.label} <span class="caret" aria-hidden="true">▾</span>
          </a>
          <div class="drop-menu">
            {item.children.map((c) => (
              <a href={demoHref(c.href)} aria-disabled={demoHref(c.href) ? undefined : "true"}>{c.label}</a>
            ))}
          </div>
        </div>
      ) : (
        <a href={demoHref(item.href)} aria-disabled={demoHref(item.href) ? undefined : "true"}>{item.label}</a>
      ),
    )}
    <a class="btn" href="/book/">Book Now</a>
  </nav>
</header>

<script>
  // Touch devices get no hover: first tap opens the dropdown, a second tap
  // on the parent follows its link (anchor). Desktop keeps hover + plain click.
  if (window.matchMedia("(hover: none)").matches) {
    const drops = document.querySelectorAll<HTMLElement>(".nav-drop");
    drops.forEach((drop) => {
      const parent = drop.querySelector<HTMLAnchorElement>(".nav-parent");
      parent?.addEventListener("click", (e) => {
        if (!drop.classList.contains("open")) {
          e.preventDefault();
          drops.forEach((d) => d.classList.remove("open"));
          drop.classList.add("open");
        }
      });
    });
    document.addEventListener("click", (e) => {
      if (!(e.target as Element).closest(".nav-drop"))
        drops.forEach((d) => d.classList.remove("open"));
    });
  }
</script>

<main>
  <slot />
</main>

<footer>
  <div class="footer-inner">
    <div class="footer-brand">
      <span class="footer-brand-row">
        <img src="/images/the-hillside-retreat-emblem.png" alt="" />
        <span class="footer-wordmark">The Hillside Retreat</span>
      </span>
      <p>Secluded, tranquil accommodation on Tamborine Mountain, in the Gold Coast Hinterland.</p>
    </div>
    <nav class="footer-col" aria-label="Footer">
      <h2>Explore</h2>
      {[
        { href: "/#accommodation", label: "Accommodation" },
        { href: "/gallery/", label: "Gallery" },
        { href: "/reviews/", label: "Reviews" },
        { href: "/location/", label: "Location" },
        { href: "/guest-info/", label: "Guest Info" },
        { href: "/mountain-mobile-massage/", label: "Mobile Massage" },
      ].map((l) => (
        <a href={demoHref(l.href)} aria-disabled={demoHref(l.href) ? undefined : "true"}>{l.label}</a>
      ))}
    </nav>
    <div class="footer-col">
      <h2>Contact</h2>
      <p>25 Leona Court<br />Tamborine Mountain QLD 4272</p>
      <a href="tel:+61466990185">(+61) 0466 990 185</a>
      <a href="mailto:stay@thehillside.com.au?subject=Enquiry%3A%20Hillside%20Retreat">stay@thehillside.com.au</a>
    </div>
    <div class="footer-col">
      <h2>Book</h2>
      <p>Two hillside dwellings — book one, or both together.</p>
      <a class="btn btn-inverse" href="/book/">Book Now</a>
    </div>
  </div>
  <div class="footer-base">
    <p>© {new Date().getFullYear()} The Hillside Retreat · Tamborine Mountain, Queensland</p>
  </div>
</footer>
