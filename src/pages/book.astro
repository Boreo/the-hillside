---
import Base from "../layouts/Base.astro";
---

<Base
  title="Book Direct | The Hillside Retreat"
  description="Check availability and book Hillside House or Hillside Villa on Tamborine Mountain directly with The Hillside Retreat."
>
  <div class="book-page">
    <h1 class="sr-only">Book your stay</h1>
    <p class="book-note">
      Booking the House and Villa combined for up to eight guests? <a
        href="/contact-us/">Contact us directly</a>.
    </p>
    <div
      class="ibe"
      data-region="apac"
      data-channelcode="thehillsideretreatdirect"
      data-widget="embed"
    >
    </div>
  </div>
</Base>

<script is:inline>
  // The SiteMinder widget reads data-query-* attributes and whitelisted page
  // URL params (room_rate, currency, ...) once at load, so the currency for
  // the guest's country must be set on the embed div before the script runs.
  // Country comes from Cloudflare's same-origin /cdn-cgi/trace (no permission
  // prompt); AUD stays the default for Australia and anywhere unmapped.
  (function () {
    var currencyFor = {
      NZ: "NZD", US: "USD", GB: "GBP", CA: "CAD", JP: "JPY", SG: "SGD",
      HK: "HKD", CN: "CNY", IN: "INR", KR: "KRW", CH: "CHF", SE: "SEK",
      NO: "NOK", DK: "DKK", AE: "AED", TH: "THB", TW: "TWD", MY: "MYR",
      ID: "IDR", PH: "PHP", VN: "VND", FJ: "FJD", ZA: "ZAR", PL: "PLN",
      CZ: "CZK",
      AT: "EUR", BE: "EUR", CY: "EUR", DE: "EUR", EE: "EUR", ES: "EUR",
      FI: "EUR", FR: "EUR", GR: "EUR", HR: "EUR", IE: "EUR", IT: "EUR",
      LT: "EUR", LU: "EUR", LV: "EUR", MT: "EUR", NL: "EUR", PT: "EUR",
      SI: "EUR", SK: "EUR",
    };
    var loaded = false;
    function loadWidget(currency) {
      if (loaded) return;
      loaded = true;
      if (currency) {
        document
          .querySelector(".ibe")
          .setAttribute("data-query-currency", currency);
      }
      var s = document.createElement("script");
      s.src = "https://widget.siteminder.com/ibe.min.js";
      document.body.appendChild(s);
    }
    setTimeout(loadWidget, 1500);
    fetch("/cdn-cgi/trace")
      .then(function (r) { return r.text(); })
      .then(function (t) {
        var m = t.match(/^loc=([A-Z]+)$/m);
        loadWidget(m && currencyFor[m[1]]);
      })
      .catch(function () { loadWidget(); });
  })();
</script>

<style>
  .book-page {
    max-width: 70rem;
    margin: 0 auto;
    padding: 0.75rem 1.5rem 4rem;
  }
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip-path: inset(50%);
    white-space: nowrap;
  }
  .book-note {
    max-width: 44rem;
    margin: 0 0 0.75rem;
    font-size: 0.95rem;
  }
  /* Desktop/tablet: the widget clamps its iframe with an inline max-height of
     ~95% of the viewport, which forces an internal scrollbar; !important lifts
     the clamp so the iframe grows to its full content height and only the page
     scrolls. The widget re-applies the clamp on window resize, so this must
     stay CSS. */
  .book-page :global(.ibe iframe) {
    max-height: none !important;
    display: block;
    margin-inline: auto;
  }
  /* Phones get SiteMinder's mobile skin, a full-viewport app whose content
     height follows the iframe height — it can never be sized to content, so
     it must scroll internally. Size it to fill the screen below the header
     instead of the widget's inline 95%-of-viewport height. */
  @media (max-width: 767px) {
    .book-page :global(.ibe iframe) {
      height: calc(100dvh - 5rem) !important;
    }
  }
</style>
