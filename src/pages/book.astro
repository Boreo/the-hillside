---
import Base from "../layouts/Base.astro";
---

<Base
  title="Book Direct | The Hillside Retreat"
  description="Check availability and book Hillside House or Hillside Villa on Tamborine Mountain directly with The Hillside Retreat."
>
  <div class="book-page">
    <h1>Book your stay</h1>
    <p class="book-note">
      Book Hillside House or Hillside Villa below. To book the House and Villa
      combined for up to eight guests, <a href="/contact-us/">contact us directly</a>.
    </p>
    <div
      class="ibe"
      data-region="apac"
      data-channelcode="thehillsideretreatdirect"
      data-widget="embed"
    >
    </div>
  </div>
</Base>

<script is:inline>
  // The SiteMinder widget reads data-query-* attributes and whitelisted page
  // URL params (room_rate, currency, ...) once at load, so the currency for
  // the guest's country must be set on the embed div before the script runs.
  // Country comes from Cloudflare's same-origin /cdn-cgi/trace (no permission
  // prompt); AUD stays the default for Australia and anywhere unmapped.
  (function () {
    var currencyFor = {
      NZ: "NZD", US: "USD", GB: "GBP", CA: "CAD", JP: "JPY", SG: "SGD",
      HK: "HKD", CN: "CNY", IN: "INR", KR: "KRW", CH: "CHF", SE: "SEK",
      NO: "NOK", DK: "DKK", AE: "AED", TH: "THB", TW: "TWD", MY: "MYR",
      ID: "IDR", PH: "PHP", VN: "VND", FJ: "FJD", ZA: "ZAR", PL: "PLN",
      CZ: "CZK",
      AT: "EUR", BE: "EUR", CY: "EUR", DE: "EUR", EE: "EUR", ES: "EUR",
      FI: "EUR", FR: "EUR", GR: "EUR", HR: "EUR", IE: "EUR", IT: "EUR",
      LT: "EUR", LU: "EUR", LV: "EUR", MT: "EUR", NL: "EUR", PT: "EUR",
      SI: "EUR", SK: "EUR",
    };
    var loaded = false;
    function loadWidget(currency) {
      if (loaded) return;
      loaded = true;
      if (currency) {
        document
          .querySelector(".ibe")
          .setAttribute("data-query-currency", currency);
      }
      var s = document.createElement("script");
      s.src = "https://widget.siteminder.com/ibe.min.js";
      // The widget sizes its iframe to the booking content via iframe-resizer,
      // but only binds it on screens 768px and up; on phones it falls back to
      // a fixed-height scrolling iframe. Bind the resizer ourselves there
      // (ibe.min.js exposes it as window.iFrameResize) so the iframe always
      // tracks content height and the page scrolls as one document.
      s.onload = function () {
        var f = document.querySelector(".ibe iframe");
        if (!f) return;
        f.setAttribute("scrolling", "no");
        if (f.className.indexOf("ibefr") === -1 && window.iFrameResize) {
          window.iFrameResize({ checkOrigin: false, scrolling: false }, f);
        }
      };
      document.body.appendChild(s);
    }
    setTimeout(loadWidget, 1500);
    fetch("/cdn-cgi/trace")
      .then(function (r) { return r.text(); })
      .then(function (t) {
        var m = t.match(/^loc=([A-Z]+)$/m);
        loadWidget(m && currencyFor[m[1]]);
      })
      .catch(function () { loadWidget(); });
  })();
</script>

<style>
  .book-page {
    max-width: 70rem;
    margin: 0 auto;
    padding: 2.5rem 1.5rem 4rem;
  }
  .book-note {
    max-width: 44rem;
    margin: 0 0 2rem;
  }
  /* The widget clamps its iframe with an inline max-height of ~95% of the
     viewport, which forces an internal scrollbar; !important lifts the clamp
     so the iframe grows to its full content height and only the page scrolls.
     It also re-applies the clamp on window resize, so this must stay CSS. */
  .book-page :global(.ibe iframe) {
    max-height: none !important;
    display: block;
    margin-inline: auto;
  }
</style>
