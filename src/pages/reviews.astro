---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import Base from "../layouts/Base.astro";
import sunrise from "../assets/images/external/sunrise-valley-coast.jpeg";

const reviews = await getCollection("reviews");

const reviewsJsonLd = {
  "@context": "https://schema.org",
  "@type": "LodgingBusiness",
  name: "The Hillside Retreat",
  url: "https://www.thehillside.com.au/",
  review: reviews.map(({ data }) => ({
    "@type": "Review",
    reviewBody: data.quote,
    author: { "@type": "Person", name: data.author },
  })),
};
---

<Base
  title="Reviews — The Hillside Retreat"
  description="What guests are saying about their stays at The Hillside Retreat on Tamborine Mountain."
  extraJsonLd={reviewsJsonLd}
>
  <h1>Reviews</h1>
  <Image
    src={sunrise}
    alt="Sunrise over the valley and coastline"
    widths={[480, 800, 1200, 1600]}
    sizes="(max-width: 71rem) 100vw, 68rem"
  />
  <p>What people are saying about The Hillside Retreat.</p>
  {
    reviews.map(({ data }) => (
      <blockquote>
        <p>“{data.quote}”</p>
        <footer>
          — {data.author}, {data.location}
        </footer>
      </blockquote>
    ))
  }
  <p><a class="btn" href="/book/">Book with us</a></p>
</Base>
