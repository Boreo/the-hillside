---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";

const reviews = await getCollection("reviews");

const reviewsJsonLd = {
  "@context": "https://schema.org",
  "@type": "LodgingBusiness",
  name: "The Hillside Retreat",
  url: "https://www.thehillside.com.au/",
  review: reviews.map(({ data }) => ({
    "@type": "Review",
    reviewBody: data.quote,
    author: { "@type": "Person", name: data.author },
  })),
};
---

<Base
  title="Reviews — The Hillside Retreat"
  description="What guests are saying about their stays at The Hillside Retreat on Tamborine Mountain."
  extraJsonLd={reviewsJsonLd}
>
  <h1>Reviews</h1>
  <img src="/images/dining-area.jpeg" alt="Dining area at The Hillside Retreat" />
  <p>What people are saying about The Hillside Retreat.</p>
  {
    reviews.map(({ data }) => (
      <blockquote>
        <p>“{data.quote}”</p>
        <footer>
          — {data.author}, {data.location}
        </footer>
      </blockquote>
    ))
  }
  <p><a class="btn" href="https://book-directonline.com/properties/thehillsideretreatdirect">Book Now</a></p>
</Base>
