---
import { getCollection } from "astro:content";
import { Image, getImage } from "astro:assets";
import Base from "../layouts/Base.astro";
import galleryRaw from "../content/gallery.yaml?raw";

// getCollection returns entries keyed by id, not in file order; the yaml file
// carries the curated display order (drone > external > house > villa >
// amenities), so sort by each id's position in the raw file.
const order = new Map(
  [...galleryRaw.matchAll(/^- id: (.+)$/gm)].map((m, i) => [m[1].trim(), i]),
);
const images = (await getCollection("gallery")).sort(
  (a, b) => (order.get(a.id) ?? 99) - (order.get(b.id) ?? 99),
);
const fulls = await Promise.all(
  images.map(({ data }) => getImage({ src: data.src, width: data.src.width })),
);
---

<Base
  title="Gallery"
  description="Photo gallery of The Hillside Retreat — the house, villa, pool, views and wildlife of Tamborine Mountain."
>
  <h1>Gallery</h1>
  <div class="gallery-grid">
    {
      images.map(({ data }, i) => (
        <a href={fulls[i].src} class="lightbox-open" data-index={i}>
          <Image
            src={data.src}
            alt={data.alt}
            widths={[400, 800]}
            sizes="(max-width: 40rem) 100vw, 33vw"
            loading={i < 6 ? "eager" : "lazy"}
          />
        </a>
      ))
    }
  </div>
</Base>
