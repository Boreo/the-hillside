---
import { getCollection, render } from "astro:content";
import { getImage } from "astro:assets";
import Base, { BUSINESS_ID } from "../layouts/Base.astro";
import DwellingLayout from "../components/DwellingLayout.astro";
import CardGroups from "../components/CardGroups.astro";
import FactIcon from "../components/FactIcon.astro";

export async function getStaticPaths() {
  const pages = await getCollection("pages");
  return pages
    .filter((page) => page.id !== "index")
    .map((page) => ({
      params: { slug: page.id },
      props: { page },
    }));
}

const { page } = Astro.props;
const { Content, remarkPluginFrontmatter } = await render(page);
const dwelling = page.data.dwelling;

const dwellingHero =
  dwelling && (await getImage({ src: dwelling.hero.src, width: 1200, format: "jpg" }));
const dwellingJsonLd = dwelling && {
  "@context": "https://schema.org",
  "@type": "Accommodation",
  name: dwelling.name,
  url: new URL(Astro.url.pathname, Astro.site).href,
  image: [new URL(dwellingHero!.src, Astro.site).href],
  occupancy: {
    "@type": "QuantitativeValue",
    minValue: 1,
    maxValue: dwelling.sleeps,
    unitText: "persons",
  },
  numberOfBedrooms: dwelling.bedrooms.length,
  numberOfBathroomsTotal: dwelling.bathrooms,
  bed: dwelling.bedrooms.map((b) => ({ "@type": "BedDetails", typeOfBed: b.bed })),
  amenityFeature: dwelling.amenities.map((name) => ({
    "@type": "LocationFeatureSpecification",
    name,
    value: true,
  })),
  containedInPlace: { "@id": BUSINESS_ID },
};

// Question/answer pairs parsed by rehype-faq-page.mjs while it structures
// the page, so the JSON-LD always matches the rendered markup.
const faqItems: { question: string; answer: string }[] | undefined =
  remarkPluginFrontmatter.faqItems;
const faqJsonLd = faqItems?.length && {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqItems.map(({ question, answer }) => ({
    "@type": "Question",
    name: question,
    acceptedAnswer: { "@type": "Answer", text: answer },
  })),
};

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: Astro.site!.href,
    },
    {
      "@type": "ListItem",
      position: 2,
      name: page.data.title,
      item: new URL(Astro.url.pathname, Astro.site).href,
    },
  ],
};

const extraJsonLd = [dwellingJsonLd, faqJsonLd, breadcrumbJsonLd].filter(
  (block): block is Exclude<typeof block, false | 0 | undefined> => Boolean(block),
);
---

<Base
  title={page.data.title}
  description={page.data.description}
  extraJsonLd={extraJsonLd}
  ogImage={page.data.dwelling?.hero.src}
>
  {
    dwelling ? (
      <DwellingLayout dwelling={dwelling}>
        <Content />
      </DwellingLayout>
    ) : (
      <Content />
    )
  }
  {page.data.placeGroups && <CardGroups groups={page.data.placeGroups} />}
  {page.data.treatmentGroups && <CardGroups groups={page.data.treatmentGroups} />}
  {
    page.data.moreLinks && (
      <section class="more-links">
        {page.data.moreLinks.intro && <p>{page.data.moreLinks.intro}</p>}
        <p class="more-links-row">
          {page.data.moreLinks.links.map((l) => (
            <a class="btn btn-outline" href={l.href}>
              {l.label}
              <FactIcon name="arrow-out" />
            </a>
          ))}
        </p>
      </section>
    )
  }
  {
    page.data.notes && (
      <ul class="page-notes">
        {page.data.notes.map((note) => (
          <li>{note}</li>
        ))}
      </ul>
    )
  }
  {
    page.data.closingCta && (
      <p class="closing-cta">
        <a class="btn" href={page.data.closingCta.href}>
          {page.data.closingCta.label}
        </a>
      </p>
    )
  }
</Base>
