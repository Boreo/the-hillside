---
import { getCollection, render } from "astro:content";
import Base from "../layouts/Base.astro";
import DwellingLayout from "../components/DwellingLayout.astro";
import PlaceCards from "../components/PlaceCards.astro";
import TreatmentCards from "../components/TreatmentCards.astro";
import FactIcon from "../components/FactIcon.astro";

export async function getStaticPaths() {
  const pages = await getCollection("pages");
  return pages
    .filter((page) => page.id !== "index")
    .map((page) => ({
      params: { slug: page.id },
      props: { page },
    }));
}

const { page } = Astro.props;
const { Content } = await render(page);
const dwelling = page.data.dwelling;

const dwellingJsonLd = dwelling && {
  "@context": "https://schema.org",
  "@type": "Accommodation",
  name: dwelling.name,
  url: new URL(Astro.url.pathname, "https://www.thehillside.com.au").href,
  occupancy: { "@type": "QuantitativeValue", maxValue: dwelling.sleeps },
  numberOfBedrooms: dwelling.bedrooms.length,
  numberOfBathroomsTotal: dwelling.bathrooms,
  bed: dwelling.bedrooms.map((b) => ({ "@type": "BedDetails", typeOfBed: b.bed })),
  amenityFeature: dwelling.amenities.map((name) => ({
    "@type": "LocationFeatureSpecification",
    name,
    value: true,
  })),
  containedInPlace: { "@type": "LodgingBusiness", name: "The Hillside Retreat" },
};

// Each h3 in the body is a question; the prose beneath it (up to the next
// h2 or h3) is the answer. h2s are topic groupings, not questions.
// Markdown links flatten to their label text so answers read as plain prose.
const faqJsonLd = page.data.faqSchema && {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [...(page.body ?? "").matchAll(/^### +(.+)\n([\s\S]*?)(?=^###? |$(?![\s\S]))/gm)].map(
    ([, question, answer]) => ({
      "@type": "Question",
      name: question.trim(),
      acceptedAnswer: {
        "@type": "Answer",
        text: answer
          .replace(/\[([^\]]+)\]\([^)]*\)/g, "$1")
          .replace(/\\\n/g, " ")
          .replace(/\s+/g, " ")
          .trim(),
      },
    }),
  ),
};

const extraJsonLd = dwellingJsonLd || faqJsonLd || undefined;
---

<Base
  title={page.data.title}
  description={page.data.description}
  extraJsonLd={extraJsonLd}
  ogImage={page.data.dwelling?.hero.src}
>
  {
    page.data.heroVideo && (
      <video
        class="hero-video"
        src={page.data.heroVideo.src}
        poster={page.data.heroVideo.poster.src}
        autoplay
        muted
        loop
        playsinline
        aria-label="Aerial drone view over The Hillside Retreat towards the Gold Coast skyline"
      />
    )
  }
  {
    dwelling ? (
      <DwellingLayout dwelling={dwelling}>
        <Content />
      </DwellingLayout>
    ) : (
      <Content />
    )
  }
  {page.data.placeGroups && <PlaceCards groups={page.data.placeGroups} />}
  {page.data.treatmentGroups && <TreatmentCards groups={page.data.treatmentGroups} />}
  {
    page.data.moreLinks && (
      <section class="more-links">
        {page.data.moreLinks.intro && <p>{page.data.moreLinks.intro}</p>}
        <p class="more-links-row">
          {page.data.moreLinks.links.map((l) => (
            <a class="btn btn-outline" href={l.href}>
              {l.label}
              <FactIcon name="arrow-out" />
            </a>
          ))}
        </p>
      </section>
    )
  }
  {
    page.data.notes && (
      <ul class="page-notes">
        {page.data.notes.map((note) => (
          <li>{note}</li>
        ))}
      </ul>
    )
  }
  {
    page.data.closingCta && (
      <p class="closing-cta">
        <a class="btn" href={page.data.closingCta.href}>
          {page.data.closingCta.label}
        </a>
      </p>
    )
  }
</Base>
