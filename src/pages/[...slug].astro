---
import { getCollection, render } from "astro:content";
import Base from "../layouts/Base.astro";

export async function getStaticPaths() {
  const pages = await getCollection("pages");
  return pages.map((page) => ({
    params: { slug: page.id === "index" ? undefined : page.id },
    props: { page },
  }));
}

const { page } = Astro.props;
const { Content } = await render(page);
const dwelling = page.data.dwelling;

const bedroomSummary = (d: NonNullable<typeof dwelling>) =>
  d.bedrooms.map((b) => `${b.bed}${b.ensuite ? " (ensuite)" : ""}`).join(", ");

const dwellingJsonLd = dwelling && {
  "@context": "https://schema.org",
  "@type": "Accommodation",
  name: dwelling.name,
  url: new URL(Astro.url.pathname, "https://www.thehillside.com.au").href,
  occupancy: { "@type": "QuantitativeValue", maxValue: dwelling.sleeps },
  numberOfBedrooms: dwelling.bedrooms.length,
  bed: dwelling.bedrooms.map((b) => ({ "@type": "BedDetails", typeOfBed: b.bed })),
  amenityFeature: dwelling.amenities.map((name) => ({
    "@type": "LocationFeatureSpecification",
    name,
    value: true,
  })),
  containedInPlace: { "@type": "LodgingBusiness", name: "The Hillside Retreat" },
};
---

<Base title={page.data.title} description={page.data.description} extraJsonLd={dwellingJsonLd}>
  {
    page.data.heroVideo && (
      <video
        class="hero-video"
        src={page.data.heroVideo.src}
        poster={page.data.heroVideo.poster}
        autoplay
        muted
        loop
        playsinline
        aria-label="Aerial drone view over The Hillside Retreat towards the Gold Coast skyline"
      />
    )
  }
  {
    dwelling && (
      <p class="facts">
        Sleeps {dwelling.sleeps} · {dwelling.bedrooms.length}{" "}
        {dwelling.bedrooms.length === 1 ? "bedroom" : "bedrooms"} ({bedroomSummary(dwelling)}) ·{" "}
        {dwelling.amenities.join(" · ")}
      </p>
    )
  }
  <Content />
</Base>
