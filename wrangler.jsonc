{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"compatibility_date": "2026-07-13",
	"compatibility_flags": ["global_fetch_strictly_public"],
	"name": "the-hillside",
	"assets": {
		"directory": "./dist/client",
		"not_found_handling": "404-page"
	},
	"observability": {
		"enabled": true
	}
}